# --- MySQL Database Configuration ---
# 데이터베이스 서버 주소 (기본값: localhost)
DB_HOST=127.0.0.1
# 데이터베이스 사용자 이름
DB_USER=root
# 데이터베이스 비밀번호
DB_PASSWORD=
# 데이터베이스 이름
DB_NAME=gutenberg
# 데이터베이스 포트 (기본값: 3306)
DB_PORT=3306

# --- Firebase & Google Cloud Configuration ---
# Firebase Admin SDK와 Google Cloud API를 위한 서비스 계정 JSON 파일의 절대 경로
# 예: GOOGLE_APPLICATION_CREDENTIALS="C:/Users/YourUser/Downloads/serviceAccountKey.json"
# 이 환경 변수를 설정하면 firebase-admin과 google-cloud-translate 라이브러리가 자동으로 인식합니다.
GOOGLE_APPLICATION_CREDENTIALS=

# Firebase Storage 버킷 URL (gs:// 제외)
# 예: my-project-12345.appspot.com
FIREBASE_STORAGE_BUCKET=

# Google Cloud 프로젝트 ID (Translation API용)
GOOGLE_PROJECT_ID=
